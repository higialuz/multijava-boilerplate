[Unit]
Description=gunicorn daemon for multijava
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/multijava/system
ExecStart=/home/ec2-user/multijava/system/venv/bin/gunicorn \
    core.wsgi:application \
    --bind 127.0.0.1:8000 \
    --workers 2
Restart=always

[Install]
WantedBy=multi-user.target
